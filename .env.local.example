# Janagana local development template
#
# Copy this to .env.local for local development. It intentionally contains only
# the smallest set needed for onboarding, dashboard, and E2E. Keep real secrets
# private and never commit .env.local.

# -----------------------------------------------------------------------------
# Local app URL
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
TENANT_APP_BASE_URL="${NEXT_PUBLIC_APP_URL}"
TENANT_API_BASE_URL="${TENANT_APP_BASE_URL}/api"
JANAGANA_BASE_URL="${NEXT_PUBLIC_APP_URL}"
PLAYWRIGHT_BASE_URL="${NEXT_PUBLIC_APP_URL}"

# -----------------------------------------------------------------------------
# Required secrets - fill from your providers
# -----------------------------------------------------------------------------
DATABASE_URL=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_WEBHOOK_SECRET=""

# -----------------------------------------------------------------------------
# Clerk routes
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/onboarding"
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=""
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=""

# -----------------------------------------------------------------------------
# Tenant profile - required before onboarding health is green
# -----------------------------------------------------------------------------
TENANT_SLUG="demo"
TENANT_BRAND_NAME="Janagana Demo"
TENANT_BRAND_LEGAL_NAME="Janagana Demo"
TENANT_BRAND_PRIMARY_COLOR="#4F46E5"
TENANT_DEFAULT_LOCALE="en-US"
TENANT_DEFAULT_TIMEZONE="America/New_York"

TENANT_TAG_NAMESPACE_DEFAULT="${TENANT_SLUG}"
TENANT_TAG_NAMESPACE_EVENT_PREFIX="event"
TENANT_TAG_NAMESPACE_CONTACT_PREFIX="contact"

TENANT_ONBOARDING_DEFAULT_ORG_NAME="${TENANT_BRAND_NAME}"
TENANT_ONBOARDING_DEFAULT_TIMEZONE="${TENANT_DEFAULT_TIMEZONE}"
TENANT_ONBOARDING_DEFAULT_PRIMARY_COLOR="${TENANT_BRAND_PRIMARY_COLOR}"

TENANT_FEATURE_FLAGS_JSON="{}"
TENANT_INTEGRATIONS_JSON="{}"
TENANT_ONBOARDING_DEFAULTS_JSON="{}"
TENANT_PLUGIN_API_ENABLED="true"
TENANT_EMBED_API_ENABLED="true"
TENANT_WEBHOOK_BASE_URL=""

ONBOARDING_DEFAULT_API_KEY_NAME="Default Plugin Key"
ONBOARDING_DEFAULT_API_KEY_PERMISSIONS="contacts:write,events:read,events:write"
NEXT_PUBLIC_SHOW_EXPERIMENTAL_FEATURES="false"

# -----------------------------------------------------------------------------
# Admin and local E2E
# -----------------------------------------------------------------------------
PLATFORM_BRAND_NAME="Janagana"
GLOBAL_ADMIN_EMAILS=""
APP_ENV="development"
GLOBAL_ADMIN_ALLOWED_ENVS="development,preview,staging"

E2E_SIGN_IN_PATH="/sign-in"
E2E_CLERK_EMAIL=""
E2E_CLERK_PASSWORD=""
E2E_FORCE_AUTH_SETUP="false"

# -----------------------------------------------------------------------------
# Optional integrations for local testing
# -----------------------------------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="noreply@example.com"
EMAIL_FROM_NAME="Janagana"

STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""

SMS_DISABLED="true"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

CLOUDINARY_URL=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
