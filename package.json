{
  "name": "orgflow",
  "version": "1.0.0",
  "private": true,
  "description": "OrgFlow monorepo: membership, events, volunteer, and club management SaaS",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "npm run generate --workspace @orgflow/database",
    "db:migrate": "npm run migrate --workspace @orgflow/database",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "test:coverage": "turbo run test --coverage"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "turbo": "^2.0.12",
    "typescript": "^5.5.4"
  },
  "packageManager": "npm@10.8.1"
}
