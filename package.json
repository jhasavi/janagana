{
  "name": "janagana",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "stop": "pkill -f 'next dev' || true",
    "restart": "npm run stop && npm run dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:ci": "next lint",
    "typecheck": "tsc --noEmit",
    "ci": "npm run lint && npm run typecheck && npm run db:generate && npm run db:migrate:deploy",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:unit:safety": "tsx --test lib/actions/organization-console.test.ts lib/actions/permissions.test.ts lib/actions/members.test.ts lib/membership-flow.test.ts",
    "test:e2e:headed": "playwright test --config=e2e/playwright.config.ts --headed",
    "test:e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "test:e2e:debug": "playwright test --config=e2e/playwright.config.ts --debug",
    "test:embed": "tsx --test lib/embed/events-utils.test.ts",
    "scripts:verify-tenants": "tsx scripts/verify-tenants.ts",
    "scripts:simulate": "tsx scripts/simulate-demo-data.ts",
    "scripts:repair": "tsx scripts/repair-orphan-tenants.ts",
    "scripts:generate-secrets": "node scripts/generate-secrets.js",
    "scripts:simulate-real-world": "tsx scripts/simulate-real-world.ts",
    "scripts:simulate-real-world-details": "tsx scripts/simulate-real-world-details.ts",
    "scripts:verify-seeded-tenants": "tsx scripts/verify-seeded-tenants.ts",
    "scripts:import-tpw-events": "tsx scripts/import-tpw-past-events.ts",
    "scripts:rollback-tpw-events": "tsx scripts/rollback-tpw-past-events.ts",
    "bootstrap:validate-env": "tsx scripts/bootstrap-validate-env.ts",
    "bootstrap:preflight": "tsx scripts/bootstrap-preflight.ts",
    "bootstrap:preflight:pre-onboarding": "tsx scripts/bootstrap-preflight.ts --phase=pre-onboarding",
    "bootstrap:preflight:post-onboarding": "tsx scripts/bootstrap-preflight.ts --phase=post-onboarding",
    "bootstrap:provision-tenant": "tsx scripts/bootstrap-provision-tenant.ts"
  },
