# ═══════════════════════════════════════════════════════════════════════════════
# JANAGANA - ENVIRONMENT VARIABLES EXAMPLE
# ═══════════════════════════════════════════════════════════════════════════════
# This file is safe to commit. Copy it to .env.local and fill in actual values.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── APPLICATION CONFIGURATION ───────────────────────────────────────────────────────
# Public URLs (client-side, starts with NEXT_PUBLIC_)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── TENANT PROFILE (REQUIRED FOR ISOLATED CUSTOMER DEPLOYMENTS) ───────────────────
# These values define one isolated customer environment (one env + one DB).
TENANT_SLUG=demo-tenant
TENANT_BRAND_NAME="JanaGana"
TENANT_BRAND_LEGAL_NAME="JanaGana Inc"
TENANT_BRAND_PRIMARY_COLOR="#4F46E5"
TENANT_APP_BASE_URL=http://localhost:3000
TENANT_API_BASE_URL=http://localhost:3000/api
TENANT_DEFAULT_LOCALE=en-US
TENANT_DEFAULT_TIMEZONE=America/New_York

# Feature flags as JSON object of booleans (example):
# TENANT_FEATURE_FLAGS_JSON='{"dashboardBeta":false,"crmV2":true}'
TENANT_FEATURE_FLAGS_JSON='{}'

# Tag namespace defaults used for generated tags/integration conventions
TENANT_TAG_NAMESPACE_DEFAULT=demo-tenant
TENANT_TAG_NAMESPACE_EVENT_PREFIX=event
TENANT_TAG_NAMESPACE_CONTACT_PREFIX=contact

# Optional onboarding profile overrides
TENANT_ONBOARDING_DEFAULT_ORG_NAME="Demo Tenant Organization"
TENANT_ONBOARDING_DEFAULT_TIMEZONE=America/New_York
TENANT_ONBOARDING_DEFAULT_PRIMARY_COLOR="#4F46E5"
# Optional full onboarding defaults JSON override
# TENANT_ONBOARDING_DEFAULTS_JSON='{"defaultOrganizationName":"Demo Tenant Organization","timezone":"America/New_York","primaryColor":"#4F46E5"}'
TENANT_ONBOARDING_DEFAULTS_JSON='{}'

# Optional integration overrides (JSON)
# TENANT_INTEGRATIONS_JSON='{"pluginApiEnabled":true,"embedApiEnabled":true}'
TENANT_INTEGRATIONS_JSON='{}'
TENANT_PLUGIN_API_ENABLED=true
TENANT_EMBED_API_ENABLED=true
TENANT_WEBHOOK_BASE_URL=http://localhost:3000

# Onboarding default API key settings (used during tenant onboarding)
ONBOARDING_DEFAULT_API_KEY_NAME="Default Plugin Key"
ONBOARDING_DEFAULT_API_KEY_PERMISSIONS="contacts:write,events:read"

# Optional helper for bootstrap preflight plugin HTTP checks
# BOOTSTRAP_PLUGIN_API_KEY=jg_live_your_key_here
BOOTSTRAP_PLUGIN_API_KEY=

# ─── DATABASE ───────────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Local: postgresql://postgres:password@localhost:5432/janagana_dev
# Neon: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/janagana?sslmode=require
# Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
DATABASE_URL="postgresql://user:password@localhost:5432/janagana_dev"

# ─── CLERK AUTHENTICATION ───────────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com/
# Clerk Secret Key (server-side)
CLERK_SECRET_KEY=""

# Clerk Publishable Key (client-side)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""

# Optional: Customize Clerk redirect routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=

# Global admin emails for platform admin access (comma separated)
GLOBAL_ADMIN_EMAILS=admin@example.com

# Clerk Webhook Secret — get from Clerk Dashboard > Webhooks > your endpoint > Signing Secret
CLERK_WEBHOOK_SECRET=

# ─── STRIPE PAYMENTS (Optional) ────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/
# Only needed if you're implementing payment features
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Webhook secret — get this from `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=""
# Stripe Price IDs for each plan (from your Stripe dashboard Products)
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=""
NEXT_PUBLIC_STRIPE_GROWTH_PRICE_ID=""
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=""

# ─── RESEND EMAIL (Optional) ─────────────────────────────────────────────────────────
# Get from: https://resend.com/
# Only needed if you want email notifications
RESEND_API_KEY=""
EMAIL_FROM="noreply@janagana.app"
EMAIL_FROM_NAME="Janagana"

# ─── CLOUDINARY FILE UPLOAD (Optional) ─────────────────────────────────────────────────
# Get from: https://cloudinary.com/
# Only needed if you want file upload capabilities
# Option 1: Single URL (recommended — Vercel uses this format)
CLOUDINARY_URL=""
# Option 2: Individual vars (alternative to CLOUDINARY_URL)
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# ─── APPLE WALLET PASSES (Optional) ───────────────────────────────────────────────────────
# Get from: https://developer.apple.com/
# Only needed for full Apple Wallet pass integration
# Requires: Apple Developer account ($99/year), Pass Type ID, certificates
PASS_CERTIFICATE_PASSWORD=""
PASS_TYPE_IDENTIFIER=""
TEAM_IDENTIFIER=""

# ─── TWILIO SMS (Optional) ────────────────────────────────────────────────────────────────
# Get from: https://www.twilio.com/
# Only needed if you want SMS notifications
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
# Set to "true" to disable sending SMS in non-production environments.
# Useful for local/dev/staging when you don't want to actually send messages.
SMS_DISABLED="false"

# ─── SENTRY ERROR TRACKING (Optional) ───────────────────────────────────────────────────
# Get from: https://sentry.io/
# Only needed if you want error tracking
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# For uploading source maps in CI (from Sentry project settings)
SENTRY_ORG=""
SENTRY_PROJECT=""

# ─── E2E TESTING (Local only — never commit real credentials) ────────────────────────
# Create a dedicated test user in Clerk Dashboard (separate from your admin account)
# Required to run: npm run test:e2e (authenticated tests)
# Not required for: npx playwright test --project=no-auth
E2E_CLERK_EMAIL=""
E2E_CLERK_PASSWORD=""
# Explicit auth route used by Playwright global setup.
# Set this to your real sign-in path if it differs from Clerk defaults.
E2E_SIGN_IN_PATH=/auth/login

# ═══════════════════════════════════════════════════════════════════════════════
# END OF ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════════════════
