# Janagana environment reference
#
# Safe to commit. Do not put real secrets in this file.
# For local development, copy .env.local.example to .env.local and keep secrets
# in your private .env or in your shell/Vercel environment.

# -----------------------------------------------------------------------------
# 1. Core runtime - required for onboarding and dashboard
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=""
TENANT_APP_BASE_URL="${NEXT_PUBLIC_APP_URL}"
TENANT_API_BASE_URL="${TENANT_APP_BASE_URL}/api"

DATABASE_URL=""

CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_WEBHOOK_SECRET=""

NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/onboarding"
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=""
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=""

# -----------------------------------------------------------------------------
# 2. Tenant profile - required for error-less onboarding
# -----------------------------------------------------------------------------
TENANT_SLUG=""
TENANT_BRAND_NAME=""
TENANT_BRAND_LEGAL_NAME=""
TENANT_BRAND_PRIMARY_COLOR="#4F46E5"
TENANT_DEFAULT_LOCALE="en-US"
TENANT_DEFAULT_TIMEZONE="America/New_York"

TENANT_TAG_NAMESPACE_DEFAULT="${TENANT_SLUG}"
TENANT_TAG_NAMESPACE_EVENT_PREFIX="event"
TENANT_TAG_NAMESPACE_CONTACT_PREFIX="contact"

TENANT_ONBOARDING_DEFAULT_ORG_NAME="${TENANT_BRAND_NAME}"
TENANT_ONBOARDING_DEFAULT_TIMEZONE="${TENANT_DEFAULT_TIMEZONE}"
TENANT_ONBOARDING_DEFAULT_PRIMARY_COLOR="${TENANT_BRAND_PRIMARY_COLOR}"

TENANT_FEATURE_FLAGS_JSON="{}"
TENANT_INTEGRATIONS_JSON="{}"
TENANT_ONBOARDING_DEFAULTS_JSON="{}"
TENANT_PLUGIN_API_ENABLED="true"
TENANT_EMBED_API_ENABLED="true"
TENANT_WEBHOOK_BASE_URL=""

ONBOARDING_DEFAULT_API_KEY_NAME="Default Plugin Key"
ONBOARDING_DEFAULT_API_KEY_PERMISSIONS="contacts:write,events:read,events:write"

# Keep removed/experimental modules hidden in the hardened product.
NEXT_PUBLIC_SHOW_EXPERIMENTAL_FEATURES="false"

# -----------------------------------------------------------------------------
# 3. Admin and platform identity
# -----------------------------------------------------------------------------
PLATFORM_BRAND_NAME="Janagana"
GLOBAL_ADMIN_EMAILS=""
GLOBAL_ADMIN_ALLOWED_ENVS="development,preview,staging"
APP_ENV="development"

# -----------------------------------------------------------------------------
# 4. Payments - required only when billing/subscriptions are enabled
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CONNECT_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=""
NEXT_PUBLIC_STRIPE_GROWTH_PRICE_ID=""
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=""
PLATFORM_FEE_PERCENTAGE="0"

# -----------------------------------------------------------------------------
# 5. Email, SMS, and uploads - optional for local, needed for production features
# -----------------------------------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="noreply@example.com"
EMAIL_FROM_NAME="Janagana"

SMS_DISABLED="true"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

CLOUDINARY_URL=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# -----------------------------------------------------------------------------
# 6. Observability - optional locally, recommended for release
# -----------------------------------------------------------------------------
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
BUILD_ID=""

# -----------------------------------------------------------------------------
# 7. Public embeds and integrations
# -----------------------------------------------------------------------------
JANAGANA_BASE_URL="${NEXT_PUBLIC_APP_URL}"
BOOTSTRAP_PLUGIN_API_KEY=""

# -----------------------------------------------------------------------------
# 8. Local E2E testing - never commit real test credentials
# -----------------------------------------------------------------------------
PLAYWRIGHT_BASE_URL="${NEXT_PUBLIC_APP_URL}"
E2E_SIGN_IN_PATH="/sign-in"
E2E_CLERK_EMAIL=""
E2E_CLERK_PASSWORD=""
E2E_FORCE_AUTH_SETUP="false"

# -----------------------------------------------------------------------------
# 9. Seed and maintenance helpers
# -----------------------------------------------------------------------------
SEED_CLERK_ORG_ID=""
DRY_RUN="true"
