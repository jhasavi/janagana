# ═══════════════════════════════════════════════════════════════════════════════
# JANAGANA - ENVIRONMENT VARIABLES EXAMPLE
# ═══════════════════════════════════════════════════════════════════════════════
# This file is safe to commit. Copy it to .env.local and fill in actual values.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── WEB APP CONFIGURATION ───────────────────────────────────────────────────────────
# Public URLs (client-side, starts with NEXT_PUBLIC_)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_DOMAIN=localhost
NEXT_PUBLIC_ROOT_DOMAIN=localhost
NEXT_PUBLIC_TENANT_FALLBACK=demo

# ─── CLERK AUTHENTICATION ───────────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com/
# Clerk Secret Key (server-side)
CLERK_SECRET_KEY=""

# Clerk Publishable Key (client-side, also needed for JWT verification)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""

# Clerk Webhook Secret (for verifying webhook signatures)
CLERK_WEBHOOK_SECRET=""

# Optional: customise Clerk redirect routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── API CONFIGURATION ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:3000

# Database (Neon PostgreSQL)
# Get from: https://console.neon.tech/
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# Redis (Upstash)
# Get from: https://console.upstash.com/
REDIS_URL="redis://localhost:6379"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# JWT Authentication
# Generate: openssl rand -hex 64
JWT_SECRET=""
JWT_EXPIRES_IN=7d

# Member JWT Authentication (for member portal)
# Generate: openssl rand -hex 64 (different from above)
MEMBER_JWT_SECRET=""
MEMBER_JWT_EXPIRES_IN=30d

# CORS
CORS_ORIGINS=http://localhost:3000,https://janagana.namasteneedham.com
APP_URL=http://localhost:4000

# ─── STRIPE PAYMENTS ──────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CONNECT_WEBHOOK_SECRET=""
PLATFORM_FEE_PERCENTAGE=2

# Client-side Stripe key (for web app)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ─── RESEND EMAIL ─────────────────────────────────────────────────────────────────
# Get from: https://resend.com/
RESEND_API_KEY=""
EMAIL_FROM=noreply@namasteneedham.com
EMAIL_FROM_NAME=Janagana

# ─── CLOUDINARY MEDIA ───────────────────────────────────────────────────────────────
# Get from: https://cloudinary.com/
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── SENTRY ERROR TRACKING ───────────────────────────────────────────────────────────
# Get from: https://sentry.io/
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ═══════════════════════════════════════════════════════════════════════════════
# END OF ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════════════════
