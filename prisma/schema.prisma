generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum TenantStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum ContactType {
  MEMBER
  REGISTRANT
  VOLUNTEER
  DONOR
  OTHER
}

enum MembershipStatus {
  PENDING
  ACTIVE
  INACTIVE
  EXPIRED
  CANCELED
}

enum MembershipInterval {
  MONTHLY
  ANNUAL
  ONE_TIME
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  WAIVED
}

enum PaymentMethod {
  OFFLINE
  CASH
  CHECK
  CARD
  BANK_TRANSFER
  STRIPE
  OTHER
}

enum PaymentPurpose {
  MEMBERSHIP
  EVENT
  DONATION
  OTHER
}

enum CommunicationStatus {
  QUEUED
  SENT
  FAILED
  SKIPPED
}

enum CommunicationPurpose {
  PAYMENT_RECEIPT
  EVENT_CONFIRMATION
  EVENT_REMINDER
  RENEWAL_REMINDER
  GENERAL
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELED
  COMPLETED
}

enum RegistrationStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELED
  ATTENDED
  NO_SHOW
  WAITLISTED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  REGISTER
}

// ─── MODELS ───────────────────────────────────────────────────────────────────

/// An organization admin account.
/// INVARIANT: One Tenant ←→ One Clerk Organization (clerkOrgId is unique).
/// Created ONLY during explicit admin onboarding — never from public registration.
model Tenant {
  id                 String       @id @default(cuid())
  name               String
  slug               String       @unique
  clerkOrgId         String       @unique
  status             TenantStatus @default(ACTIVE)
  publicTagline      String?
  publicContactEmail String?
  publicContactPhone String?
  logoUrl            String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  tenantAdmins  TenantAdmin[]
  contacts      Contact[]
  tiers         MembershipTier[]
  memberships   Membership[]
  eventTicketTypes EventTicketType[]
  payments      PaymentRecord[]
  receipts      PaymentReceipt[]
  stripeEvents  StripeWebhookEvent[]
  communications CommunicationMessage[]
  events        Event[]
  registrations EventRegistration[]
  auditLogs     AuditLog[]
}

/// Cache of which Clerk users are admins of which Tenants.
/// Source of truth is Clerk organization membership — this is a read-cache only.
/// Always re-validate against Clerk before writes.
model TenantAdmin {
  id          String   @id @default(cuid())
  tenantId    String
  clerkUserId String
  role        String   @default("admin")
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, clerkUserId])
  @@index([clerkUserId])
}

/// A public-facing person (visitor, registrant, member, donor).
/// INVARIANT: Contacts are NEVER Clerk users.
///            Creating a Contact MUST NEVER create a Clerk Organization.
model Contact {
  id                  String      @id @default(cuid())
  tenantId            String
  firstName           String
  lastName            String
  email               String
  phone               String?
  type                ContactType @default(REGISTRANT)
  source              String?
  interestType        String?
  lastActivityAt      DateTime?
  lastActivitySummary String?
  notes               String?
  tags                String[]    @default([])
  externalSource      String?
  externalId          String?
  importedAt          DateTime?
  originalMetadata    Json?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships   Membership[]
  registrations EventRegistration[]
  payments      PaymentRecord[]
  receipts      PaymentReceipt[]
  communications CommunicationMessage[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, source])
  @@index([tenantId, interestType])
  @@index([tenantId, lastActivityAt])
}

/// A membership plan offered by a tenant.
model MembershipTier {
  id            String             @id @default(cuid())
  tenantId      String
  name          String
  description   String?
  amountCents   Int
  interval      MembershipInterval
  stripePriceId String?
  active        Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships Membership[]

  @@index([tenantId])
}

/// A contact's enrollment in a membership tier.
model Membership {
  id        String           @id @default(cuid())
  tenantId  String
  contactId String
  tierId    String
  status    MembershipStatus @default(ACTIVE)
  startsAt  DateTime         @default(now())
  expiresAt DateTime?
  autoRenew Boolean          @default(false)
  source    String           @default("admin")
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tier    MembershipTier @relation(fields: [tierId], references: [id])
  payments PaymentRecord[]
  receipts PaymentReceipt[]
  communications CommunicationMessage[]

  @@index([tenantId])
  @@index([contactId])
  @@index([tenantId, status])
  @@index([tenantId, expiresAt])
}

/// Tenant-scoped money ledger. Stripe/offline/donation/event payments all land here.
model PaymentRecord {
  id             String         @id @default(cuid())
  tenantId       String
  contactId      String?
  membershipId   String?
  eventId        String?
  registrationId String?
  amountCents    Int
  currency       String         @default("USD")
  status         PaymentStatus  @default(PAID)
  method         PaymentMethod  @default(OFFLINE)
  purpose        PaymentPurpose @default(MEMBERSHIP)
  provider       String?
  providerRef    String?
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact    Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  membership Membership? @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  event      Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  registration EventRegistration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  receipt    PaymentReceipt?

  @@index([tenantId])
  @@index([tenantId, purpose])
  @@index([tenantId, status])
  @@index([contactId])
  @@index([membershipId])
  @@index([eventId])
  @@index([registrationId])
  @@index([paidAt])
  @@unique([provider, providerRef])
}

/// Issued proof of payment for a completed transaction.
model PaymentReceipt {
  id             String   @id @default(cuid())
  tenantId       String
  paymentId      String   @unique
  contactId      String?
  membershipId   String?
  receiptNumber  String   @unique
  recipientEmail String
  recipientName  String?
  amountCents    Int
  currency       String   @default("USD")
  description    String
  issuedAt       DateTime @default(now())
  createdAt      DateTime @default(now())

  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payment    PaymentRecord @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  contact    Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  membership Membership?   @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  communications CommunicationMessage[]

  @@index([tenantId])
  @@index([contactId])
  @@index([membershipId])
  @@index([issuedAt])
}

/// Idempotency marker for Stripe webhooks already processed.
model StripeWebhookEvent {
  id            String   @id @default(cuid())
  tenantId      String?
  stripeEventId String   @unique
  eventType     String
  processedAt   DateTime @default(now())
  metadata      Json?

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([processedAt])
}

/// An event created by a tenant admin.
model Event {
  id          String      @id @default(cuid())
  tenantId    String
  title       String
  slug        String
  description String?
  startsAt    DateTime
  location    String?
  status      EventStatus @default(DRAFT)
  priceCents  Int         @default(0)
  capacity    Int?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticketTypes   EventTicketType[]
  registrations EventRegistration[]
  payments      PaymentRecord[]
  communications CommunicationMessage[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

/// A purchasable or free ticket option for a tenant event.
model EventTicketType {
  id               String   @id @default(cuid())
  tenantId         String
  eventId          String
  name             String
  description      String?
  priceCents       Int      @default(0)
  memberPriceCents Int?
  capacity         Int?
  active           Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event         Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrations EventRegistration[]

  @@index([tenantId])
  @@index([eventId])
}

/// A public visitor's registration for an event.
/// INVARIANT: Creating an EventRegistration MUST NEVER create a Clerk Organization.
model EventRegistration {
  id        String             @id @default(cuid())
  tenantId  String
  eventId   String
  contactId String
  ticketTypeId String?
  quantity  Int                @default(1)
  amountCents Int              @default(0)
  status    RegistrationStatus @default(CONFIRMED)
  checkedInAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  ticketType EventTicketType? @relation(fields: [ticketTypeId], references: [id], onDelete: SetNull)
  payments PaymentRecord[]
  communications CommunicationMessage[]

  @@unique([eventId, contactId])
  @@index([tenantId])
  @@index([eventId])
  @@index([ticketTypeId])
}

/// Transactional communication outbox. Provider delivery can process queued rows.
model CommunicationMessage {
  id             String               @id @default(cuid())
  tenantId       String
  contactId      String?
  membershipId   String?
  eventId        String?
  registrationId String?
  receiptId      String?
  purpose        CommunicationPurpose
  status         CommunicationStatus  @default(QUEUED)
  recipientEmail String
  recipientName  String?
  subject        String
  body           String
  scheduledFor   DateTime?
  sentAt         DateTime?
  provider       String?
  providerRef    String?
  error          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact      Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  membership   Membership?        @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  event        Event?             @relation(fields: [eventId], references: [id], onDelete: SetNull)
  registration EventRegistration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  receipt      PaymentReceipt?    @relation(fields: [receiptId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([contactId])
  @@index([membershipId])
  @@index([eventId])
  @@index([registrationId])
  @@index([receiptId])
  @@index([tenantId, status])
  @@index([scheduledFor])
}

/// Immutable audit trail for all tenant operations.
model AuditLog {
  id          String      @id @default(cuid())
  tenantId    String?
  actorUserId String?
  action      AuditAction
  metadata    Json?
  createdAt   DateTime    @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([createdAt])
}
