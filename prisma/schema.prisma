generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum MemberStatus {
  ACTIVE
  INACTIVE
  PENDING
  BANNED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELED
  COMPLETED
}

enum EventFormat {
  IN_PERSON
  VIRTUAL
  HYBRID
}

enum RegistrationStatus {
  CONFIRMED
  CANCELED
  ATTENDED
  NO_SHOW
  WAITLISTED
}

enum VolunteerStatus {
  OPEN
  CLOSED
  CANCELED
  COMPLETED
}

enum SignupStatus {
  CONFIRMED
  CANCELED
  COMPLETED
}

enum HoursStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ClubRole {
  OWNER
  ADMIN
  MEMBER
}

enum ShiftSignupStatus {
  CONFIRMED
  CANCELED
  ATTENDED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

enum FieldType {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  BOOLEAN
  SELECT
  URL
  PHONE
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  FILLED
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  // VOLUNTEER kept for backward compat — new volunteer postings use VolunteerOpportunity
  // Do NOT use for new records; filter it out in UI queries
  VOLUNTEER
}

enum ForumCategory {
  GENERAL
  ANNOUNCEMENTS
  QUESTIONS
  INTRODUCTIONS
  FEEDBACK
  PROJECTS
  OTHER
}

enum FormFieldType {
  TEXT
  TEXTAREA
  EMAIL
  PHONE
  NUMBER
  DATE
  SELECT
  CHECKBOX
  RADIO
  FILE
  HEADING
  PARAGRAPH
}

enum LifecycleStage {
  PROSPECT
  ENGAGED
  APPLICANT
  MEMBER
  VOLUNTEER
  DONOR
  LAPSED
  ADVOCATE
}

enum OfficerTermStatus {
  ACTIVE
  COMPLETED
  RESIGNED
  REMOVED
}

enum JobApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

enum DuplicateStatus {
  PENDING
  MERGED
  DISMISSED
}

// ─── TENANT ──────────────────────────────────────────────────────────────────

model Tenant {
  id           String   @id @default(cuid())
  clerkOrgId   String   @unique
  name         String
  slug         String   @unique
  logoUrl      String?
  primaryColor String   @default("#4F46E5")
  timezone     String   @default("America/New_York")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Stripe platform billing
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  planSlug             String  @default("free")
  planExpiresAt        DateTime?

  members                Member[]
  membershipTiers        MembershipTier[]
  membershipEnrollments  MembershipEnrollment[]
  households             Household[]
  events                 Event[]
  volunteerOpportunities VolunteerOpportunity[]
  clubs                  Club[]
  donationCampaigns      DonationCampaign[]
  donations              Donation[]
  apiKeys                ApiKey[]
  notifications          Notification[]
  webhookEndpoints       WebhookEndpoint[]
  emailCampaigns         EmailCampaign[]
  customFields           MemberCustomField[]
  contactCustomFields    ContactCustomField[]
  jobPostings            JobPosting[]
  forumThreads           ForumThread[]
  forms                  CustomForm[]
  memberDocuments        MemberDocument[]
  contactDocuments       ContactDocument[]
  contentPages           ContentPage[]
  photoAlbums            PhotoAlbum[]
  photos                 Photo[]
  surveys                Survey[]
  chapters               Chapter[]
  chapterMembers         ChapterMember[]
  companies              Company[]
  contacts               Contact[]
  deals                  Deal[]
  activities             Activity[]
  tasks                  Task[]
  governanceOffices      GovernanceOffice[]
  officerTerms           OfficerTerm[]
  committees             Committee[]
  committeeMemberships   CommitteeMembership[]
  jobApplications        JobApplication[]
  duplicateSuggestions   DuplicateSuggestion[]

  @@index([clerkOrgId])
}

// ─── HOUSEHOLD ───────────────────────────────────────────────────────────────

model Household {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name           String
  primaryContactId String?
  primaryContact Contact? @relation("HouseholdPrimaryContact", fields: [primaryContactId], references: [id])

  contacts       Contact[] @relation("ContactHousehold")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
}

// ─── MEMBER (Legacy - to be migrated to Contact + MembershipEnrollment) ─────

model Member {
  id          String       @id @default(cuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  email       String
  firstName   String
  lastName    String
  phone       String?
  avatarUrl   String?
  dateOfBirth DateTime?
  address     String?
  city        String?
  state       String?
  postalCode  String?
  country     String       @default("US")
  bio         String?      @db.Text

  status      MemberStatus @default(ACTIVE)
  tierId      String?
  tier        MembershipTier? @relation(fields: [tierId], references: [id])

  joinedAt    DateTime     @default(now())
  renewsAt    DateTime?
  notes       String?      @db.Text

  stripeCustomerId        String?
  stripeSubscriptionId    String?
  clerkUserId             String?
  smsOptIn                Boolean  @default(false)

  chapterId            String?
  chapter              Chapter?       @relation(fields: [chapterId], references: [id])
  chapterMemberships   ChapterMember[]

  clubMemberships      ClubMembership[]
  clubPosts            ClubPost[]
  donations            Donation[]
  notifications        Notification[]
  eventRegistrations   EventRegistration[]
  volunteerSignups     VolunteerSignup[]
  customFieldValues    MemberCustomFieldValue[]
  jobPostings          JobPosting[]             @relation("MemberJobPostings")
  forumThreads         ForumThread[]
  forumReplies         ForumReply[]
  documents            MemberDocument[]
  contact              Contact?                 @relation("MemberContact")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, status])
}

// ─── MEMBERSHIP ENROLLMENT (New canonical model) ─────────────────────────────

model MembershipEnrollment {
  id          String       @id @default(cuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact      @relation("ContactEnrollments", fields: [contactId], references: [id], onDelete: Cascade)

  tierId      String?
  tier        MembershipTier? @relation("MembershipEnrollmentTier", fields: [tierId], references: [id])

  status      MemberStatus @default(ACTIVE)
  startDate   DateTime     @default(now())
  endDate     DateTime?
  renewalDate DateTime?

  // Billing
  stripeCustomerId     String?
  stripeSubscriptionId String?
  paymentStatus        String?

  // Membership-specific
  memberNumber String?
  benefits    String[] @default([])
  notes       String?  @db.Text

  // Chapter (if applicable)
  chapterId   String?
  chapter     Chapter?   @relation("MembershipEnrollmentChapter", fields: [chapterId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([contactId, tierId, startDate])
  @@index([tenantId])
  @@index([contactId])
  @@index([tenantId, status])
}

// ─── MEMBERSHIP TIER ─────────────────────────────────────────────────────────

model MembershipTier {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String?
  priceCents  Int      @default(0)
  interval    BillingInterval @default(ANNUAL)
  isActive    Boolean  @default(true)
  color       String   @default("#4F46E5")
  benefits    String[] @default([])

  stripePriceId String?

  members     Member[]
  enrollments MembershipEnrollment[] @relation("MembershipEnrollmentTier")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

// ─── EVENT ───────────────────────────────────────────────────────────────────

model Event {
  id             String      @id @default(cuid())
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title          String
  description    String?     @db.Text
  startDate      DateTime
  endDate        DateTime?
  location       String?
  virtualLink    String?
  capacity       Int?
  coverImageUrl  String?
  priceCents     Int         @default(0)
  tags           String[]    @default([])

  status         EventStatus @default(DRAFT)
  format         EventFormat @default(IN_PERSON)

  registrations  EventRegistration[]

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([tenantId])
  @@index([tenantId, startDate])
  @@index([tenantId, status])
}

// ─── EVENT REGISTRATION ──────────────────────────────────────────────────────

model EventRegistration {
  id          String             @id @default(cuid())
  eventId     String
  event       Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  memberId    String
  member      Member             @relation(fields: [memberId], references: [id], onDelete: Cascade)
  contactId   String?
  contact     Contact?           @relation("ContactEventRegistrations", fields: [contactId], references: [id], onDelete: SetNull)

  status      RegistrationStatus @default(CONFIRMED)
  ticketCode  String             @unique @default(cuid())
  paidAmount  Int                @default(0)
  stripePaymentId String?

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([eventId, memberId])
  @@unique([eventId, contactId])
  @@index([eventId])
  @@index([memberId])
  @@index([contactId])
}

// ─── VOLUNTEER OPPORTUNITY ───────────────────────────────────────────────────

model VolunteerOpportunity {
  id            String          @id @default(cuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title         String
  description   String?         @db.Text
  date          DateTime?
  endDate       DateTime?
  location      String?
  capacity      Int?
  hoursEstimate Float?
  tags          String[]        @default([])

  status        VolunteerStatus @default(OPEN)

  signups       VolunteerSignup[]
  shifts        VolunteerShift[]

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
}

// ─── VOLUNTEER SIGNUP ────────────────────────────────────────────────────────

model VolunteerSignup {
  id            String        @id @default(cuid())
  opportunityId String
  opportunity   VolunteerOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  memberId      String
  member        Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  contactId     String?
  contact       Contact?      @relation("ContactVolunteerSignups", fields: [contactId], references: [id], onDelete: SetNull)

  status        SignupStatus  @default(CONFIRMED)
  hoursLogged   Float?
  hoursApproved Float?
  hoursStatus   HoursStatus?
  notes         String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([opportunityId, memberId])
  @@unique([opportunityId, contactId])
  @@index([opportunityId])
  @@index([memberId])
  @@index([contactId])
  @@index([hoursStatus])
}

// ─── AUDIT LOG ───────────────────────────────────────────────────────────────

model AuditLog {
  id           String      @id @default(cuid())
  tenantId     String

  action       AuditAction
  resourceType String       // e.g. "Member", "Event", "VolunteerOpportunity"
  resourceId   String
  resourceName String?      // human-readable label for display

  actorClerkId String?      // Clerk user ID of who performed the action
  actorName    String?      // display name cache

  metadata     Json?        // diff or extra context

  createdAt    DateTime     @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, resourceType])
  @@index([tenantId, actorClerkId])
}

// ─── CLUB ─────────────────────────────────────────────────────────────────────

model Club {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String?  @db.Text
  isPrivate   Boolean  @default(false)
  isActive    Boolean  @default(true)

  memberships ClubMembership[]
  posts       ClubPost[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model ClubMembership {
  id       String   @id @default(cuid())
  clubId   String
  club     Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  memberId String
  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  contactId String?
  contact  Contact? @relation("ContactClubMemberships", fields: [contactId], references: [id], onDelete: SetNull)

  role     ClubRole @default(MEMBER)

  joinedAt DateTime @default(now())

  @@unique([clubId, memberId])
  @@unique([clubId, contactId])
  @@index([clubId])
  @@index([memberId])
  @@index([contactId])
}

model ClubPost {
  id       String @id @default(cuid())
  clubId   String
  club     Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  contactId String?
  contact  Contact? @relation("ContactClubPosts", fields: [contactId], references: [id], onDelete: SetNull)

  content  String  @db.Text
  isPinned Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
  @@index([memberId])
  @@index([contactId])
}

// ─── FUNDRAISING ─────────────────────────────────────────────────────────────

model DonationCampaign {
  id           String         @id @default(cuid())
  tenantId     String
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title        String
  description  String?        @db.Text
  goalCents    Int            @default(0)
  raisedCents  Int            @default(0)
  status       CampaignStatus @default(DRAFT)
  coverImageUrl String?
  endDate      DateTime?
  stripePriceId String?

  donations    Donation[]

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
}

model Donation {
  id           String         @id @default(cuid())
  tenantId     String
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaignId   String?
  campaign     DonationCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  memberId     String?
  member       Member?        @relation(fields: [memberId], references: [id], onDelete: SetNull)
  contactId    String?
  contact      Contact?       @relation("ContactDonations", fields: [contactId], references: [id], onDelete: SetNull)

  amountCents  Int
  donorName    String
  donorEmail   String
  message      String?        @db.Text
  status       DonationStatus @default(PENDING)
  stripePaymentId String?
  isAnonymous  Boolean        @default(false)

  createdAt    DateTime       @default(now())

  @@index([tenantId])
  @@index([campaignId])
  @@index([memberId])
  @@index([contactId])
}

// ─── VOLUNTEER SHIFTS ────────────────────────────────────────────────────────

model VolunteerShift {
  id            String               @id @default(cuid())
  opportunityId String
  opportunity   VolunteerOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  title         String?
  startTime     DateTime
  endTime       DateTime
  capacity      Int?
  location      String?

  signups       VolunteerShiftSignup[]

  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([opportunityId])
}

model VolunteerShiftSignup {
  id       String            @id @default(cuid())
  shiftId  String
  shift    VolunteerShift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  memberId String
  // no direct Member relation here — resolved via shiftId→opportunity→tenantId

  status   ShiftSignupStatus @default(CONFIRMED)

  createdAt DateTime         @default(now())

  @@unique([shiftId, memberId])
  @@index([shiftId])
  @@index([memberId])
}

// ─── API KEYS ─────────────────────────────────────────────────────────────────

model ApiKey {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  keyHash     String   @unique     // SHA-256 of the raw key
  keyPrefix   String               // first 8 chars shown in UI (e.g. jg_live_)
  permissions String[] @default([])// e.g. ["members:read", "events:write"]
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?

  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([keyHash])
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────────

model Notification {
  id           String           @id @default(cuid())
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberId     String?          // null = admin/system notification
  member       Member?          @relation(fields: [memberId], references: [id], onDelete: Cascade)
  contactId    String?
  contact      Contact?         @relation("ContactNotifications", fields: [contactId], references: [id], onDelete: SetNull)

  title        String
  body         String
  type         NotificationType @default(INFO)
  isRead       Boolean          @default(false)
  resourceType String?          // e.g. "Member", "Event"
  resourceId   String?
  actionUrl    String?

  createdAt    DateTime         @default(now())

  @@index([tenantId, isRead])
  @@index([tenantId, memberId])
  @@index([tenantId, contactId])
}

// ─── WEBHOOK ENDPOINTS ────────────────────────────────────────────────────────

model WebhookEndpoint {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  url       String
  events    String[]  @default([])  // e.g. ["member.created", "event.published"]
  secret    String                  // HMAC signing secret
  isActive  Boolean   @default(true)

  deliveries WebhookDelivery[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId])
}

model WebhookDelivery {
  id         String          @id @default(cuid())
  endpointId String
  endpoint   WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  event      String
  payload    Json
  statusCode Int?
  success    Boolean         @default(false)
  error      String?

  createdAt  DateTime        @default(now())

  @@index([endpointId])
}

// ─── EMAIL CAMPAIGNS ─────────────────────────────────────────────────────────

model EmailCampaign {
  id             String              @id @default(cuid())
  tenantId       String
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name           String
  subject        String
  htmlBody       String              @db.Text
  status         EmailCampaignStatus @default(DRAFT)
  recipientCount Int                 @default(0)
  sentAt         DateTime?

  // Targeting
  targetTierIds  String[]            @default([])  // empty = all members
  targetStatuses String[]            @default([])  // empty = all statuses

  logs           EmailLog[]

  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
}

model EmailLog {
  id         String       @id @default(cuid())
  campaignId String
  campaign   EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  email      String
  status     String        @default("sent")  // "sent", "bounced", "opened"
  sentAt     DateTime      @default(now())

  @@index([campaignId])
}

// ─── MEMBER CUSTOM FIELDS (Legacy) ────────────────────────────────────────────

model MemberCustomField {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  fieldName  String
  fieldKey   String          // slugified identifier, used as key in values
  fieldType  FieldType       @default(TEXT)
  isRequired Boolean         @default(false)
  isActive   Boolean         @default(true)
  options    String[]        @default([]) // for SELECT type
  sortOrder  Int             @default(0)
  helpText   String?

  values    MemberCustomFieldValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, fieldKey])
  @@index([tenantId])
}

model MemberCustomFieldValue {
  id       String            @id @default(cuid())
  fieldId  String
  field    MemberCustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  memberId String
  member   Member            @relation(fields: [memberId], references: [id], onDelete: Cascade)

  value    String            @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fieldId, memberId])
  @@index([fieldId])
  @@index([memberId])
}

// ─── CONTACT CUSTOM FIELDS (New canonical model) ───────────────────────────────

model ContactCustomField {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  fieldName  String
  fieldKey   String          // slugified identifier, used as key in values
  fieldType  FieldType       @default(TEXT)
  isRequired Boolean         @default(false)
  isActive   Boolean         @default(true)
  options    String[]        @default([]) // for SELECT type
  sortOrder  Int             @default(0)
  helpText   String?

  values    ContactCustomFieldValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, fieldKey])
  @@index([tenantId])
}

model ContactCustomFieldValue {
  id       String              @id @default(cuid())
  fieldId  String
  field    ContactCustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)

  value    String              @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fieldId, contactId])
  @@index([fieldId])
  @@index([contactId])
}

// ─── JOB BOARD ───────────────────────────────────────────────────────────────

model JobPosting {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title       String
  company     String?
  location    String?
  isRemote    Boolean   @default(false)
  description String    @db.Text
  applyUrl    String?
  applyEmail  String?
  salaryMin   Int?      // in cents or annual dollars — store raw
  salaryMax   Int?
  salaryCurrency String @default("USD")

  jobType     JobType   @default(FULL_TIME)
  status      JobStatus @default(DRAFT)
  isFeatured  Boolean   @default(false)
  isPaid      Boolean   @default(false)      // paid listing
  expiresAt   DateTime?
  tags        String[]  @default([])

  postedByMemberId String?
  postedByMember   Member?  @relation("MemberJobPostings", fields: [postedByMemberId], references: [id], onDelete: SetNull)
  postedByContactId String?
  postedByContact  Contact? @relation("ContactJobPostings", fields: [postedByContactId], references: [id], onDelete: SetNull)

  applications     JobApplication[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, expiresAt])
}

// ─── FORUM ───────────────────────────────────────────────────────────────────

model ForumThread {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title       String
  body        String        @db.Text
  category    ForumCategory @default(GENERAL)
  isPinned    Boolean       @default(false)
  isLocked    Boolean       @default(false)
  isClosed    Boolean       @default(false)
  viewCount   Int           @default(0)
  replyCount  Int           @default(0)
  tags        String[]      @default([])

  authorMemberId String?
  author         Member?    @relation(fields: [authorMemberId], references: [id], onDelete: SetNull)
  authorContactId String?
  authorContact  Contact?   @relation("ContactForumThreads", fields: [authorContactId], references: [id], onDelete: SetNull)

  lastReplyAt DateTime?
  replies     ForumReply[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, category])
  @@index([tenantId, isPinned, lastReplyAt])
}

model ForumReply {
  id       String @id @default(cuid())
  threadId String
  thread   ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  body         String  @db.Text
  isAdminReply Boolean @default(false)

  authorMemberId String?
  author         Member? @relation(fields: [authorMemberId], references: [id], onDelete: SetNull)
  authorContactId String?
  authorContact  Contact? @relation("ContactForumReplies", fields: [authorContactId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([threadId])
  @@index([authorMemberId])
  @@index([authorContactId])
}

// ─── FORM BUILDER ────────────────────────────────────────────────────────────

model CustomForm {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title       String
  description String?  @db.Text
  slug        String                  // used for public embed: /portal/[org]/forms/[slug]
  isPublished Boolean  @default(false)
  isArchived  Boolean  @default(false)
  requiresAuth Boolean @default(false) // gated to logged-in portal members
  confirmationMessage String?  @db.Text
  redirectUrl  String?
  maxSubmissions Int?

  fields      FormField[]
  submissions FormSubmission[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model FormField {
  id        String        @id @default(cuid())
  formId    String
  form      CustomForm    @relation(fields: [formId], references: [id], onDelete: Cascade)

  fieldType FormFieldType
  label     String
  fieldKey  String                  // unique within form
  placeholder String?
  helpText  String?
  isRequired Boolean      @default(false)
  options   String[]      @default([]) // for SELECT, RADIO, CHECKBOX
  sortOrder Int           @default(0)
  content   String?       @db.Text    // for HEADING / PARAGRAPH display text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([formId, fieldKey])
  @@index([formId])
}

model FormSubmission {
  id        String     @id @default(cuid())
  formId    String
  form      CustomForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  data      Json                     // { fieldKey: value }
  submitterEmail String?
  submitterName  String?
  memberId  String?                  // linked if authenticated

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([formId])
  @@index([formId, createdAt])
}

// ─── MEMBER DOCUMENTS (Legacy) ────────────────────────────────────────────────

enum DocumentType {
  GENERAL
  ID_PROOF
  ADDRESS_PROOF
  MEMBERSHIP_FORM
  WAIVER
  CERTIFICATE
  PHOTO
  OTHER
}

model MemberDocument {
  id           String       @id @default(cuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberId     String
  member       Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)

  fileName     String
  fileUrl      String       // Cloudinary secure_url
  publicId     String       // Cloudinary public_id for deletion
  fileType     String       // MIME type e.g. application/pdf
  fileSizeBytes Int?
  documentType DocumentType @default(GENERAL)
  description  String?

  uploadedBy   String?      // Clerk user ID of uploader (admin)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([tenantId])
  @@index([memberId])
}

// ─── CONTACT DOCUMENTS (New canonical model) ─────────────────────────────────────

model ContactDocument {
  id           String       @id @default(cuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId    String
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  fileName     String
  fileUrl      String       // Cloudinary secure_url
  publicId     String       // Cloudinary public_id for deletion
  fileType     String       // MIME type e.g. application/pdf
  fileSizeBytes Int?
  documentType DocumentType @default(GENERAL)
  description  String?

  uploadedBy   String?      // Clerk user ID of uploader (admin)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([tenantId])
  @@index([contactId])
}

// ─── CMS PAGES ───────────────────────────────────────────────────────────────

model ContentPage {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title       String
  slug        String
  content     String   @db.Text  // HTML content
  excerpt     String?
  isPublished Boolean  @default(false)
  sortOrder   Int      @default(0)
  showInNav   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, isPublished])
}

// ─── PHOTO GALLERY ────────────────────────────────────────────────────────────

model PhotoAlbum {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title       String
  description String?
  coverUrl    String?
  isPublished Boolean  @default(false)
  sortOrder   Int      @default(0)

  photos      Photo[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model Photo {
  id          String      @id @default(cuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  albumId     String?
  album       PhotoAlbum? @relation(fields: [albumId], references: [id], onDelete: SetNull)

  title       String?
  caption     String?
  fileUrl     String
  publicId    String      // Cloudinary public_id
  width       Int?
  height      Int?
  sortOrder   Int         @default(0)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([tenantId])
  @@index([albumId])
}

// ─── SURVEYS & POLLS ─────────────────────────────────────────────────────────

enum SurveyQuestionType {
  TEXT
  TEXTAREA
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  RATING
  YES_NO
}

model Survey {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title       String
  description String?
  isPublished Boolean  @default(false)
  isAnonymous Boolean  @default(false)
  showResults Boolean  @default(false)
  closesAt    DateTime?

  questions   SurveyQuestion[]
  responses   SurveyResponse[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model SurveyQuestion {
  id         String             @id @default(cuid())
  surveyId   String
  survey     Survey             @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  text       String
  type       SurveyQuestionType @default(TEXT)
  options    String[]           @default([]) // for SINGLE_CHOICE, MULTIPLE_CHOICE
  isRequired Boolean            @default(false)
  sortOrder  Int                @default(0)

  answers    SurveyAnswer[]

  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([surveyId])
}

model SurveyResponse {
  id        String   @id @default(cuid())
  surveyId  String
  survey    Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  memberId  String?  // null if anonymous
  respondentEmail String?
  ipAddress String?

  answers   SurveyAnswer[]

  createdAt DateTime @default(now())

  @@index([surveyId])
  @@index([memberId])
}

model SurveyAnswer {
  id         String         @id @default(cuid())
  responseId String
  response   SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId String
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  value      String         @db.Text // JSON-encoded for multi-choice

  @@index([responseId])
  @@index([questionId])
}

// ─── GOVERNANCE OFFICES & COMMITTEES ─────────────────────────────────────────
// Separate from volunteer roles — models board, executive, and committee positions.

model GovernanceOffice {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title       String   // e.g. "President", "Secretary", "Board Member"
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)

  terms       OfficerTerm[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, title])
  @@index([tenantId])
}

model OfficerTerm {
  id          String            @id @default(cuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  officeId    String
  office      GovernanceOffice  @relation(fields: [officeId], references: [id], onDelete: Cascade)

  contactId   String
  contact     Contact           @relation("ContactOfficerTerms", fields: [contactId], references: [id], onDelete: Cascade)

  startDate   DateTime
  endDate     DateTime?
  status      OfficerTermStatus @default(ACTIVE)
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([contactId])
  @@index([officeId])
  @@index([tenantId, status])
}

model Committee {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String?
  isActive    Boolean  @default(true)

  memberships CommitteeMembership[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

model CommitteeMembership {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  committeeId String
  committee   Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)

  contactId   String
  contact     Contact  @relation("ContactCommitteeMemberships", fields: [contactId], references: [id], onDelete: Cascade)

  role        String?  // e.g. "Chair", "Member", "Secretary"
  startDate   DateTime @default(now())
  endDate     DateTime?
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([committeeId, contactId, startDate])
  @@index([tenantId])
  @@index([contactId])
  @@index([committeeId])
}

// ─── JOB APPLICATIONS ────────────────────────────────────────────────────────
// Lightweight applicant intake — separate lifecycle from JobPosting.

model JobApplication {
  id            String               @id @default(cuid())
  tenantId      String
  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  jobPostingId  String
  jobPosting    JobPosting           @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  contactId     String?              // linked after matching/creation
  contact       Contact?             @relation("ContactJobApplications", fields: [contactId], references: [id], onDelete: SetNull)

  // Applicant info (captured from form, before contact link)
  firstName     String
  lastName      String
  email         String
  phone         String?
  resumeUrl     String?              // Cloudinary or external URL
  coverLetter   String?              @db.Text

  status        JobApplicationStatus @default(SUBMITTED)
  source        String?              // "website", "referral", "portal"
  notes         String?              @db.Text
  rejectionReason String?

  submittedAt   DateTime             @default(now())
  reviewedAt    DateTime?
  hiredAt       DateTime?

  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([tenantId])
  @@index([jobPostingId])
  @@index([contactId])
  @@index([tenantId, status])
  @@index([email])
}

// ─── CONTACT DEDUP / MERGE ───────────────────────────────────────────────────
// Soft-warning dedup — admin reviews and merges manually. Preserves history.

model DuplicateSuggestion {
  id            String          @id @default(cuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactAId    String
  contactA      Contact         @relation("DuplicateA", fields: [contactAId], references: [id], onDelete: Cascade)

  contactBId    String
  contactB      Contact         @relation("DuplicateB", fields: [contactBId], references: [id], onDelete: Cascade)

  confidenceScore Int           @default(0)   // 0–100; higher = more confident match
  matchReason    String?                       // "email", "phone", "name+zip", "external_id"
  status         DuplicateStatus @default(PENDING)

  resolvedBy     String?         // Clerk user ID of admin who resolved
  resolvedAt     DateTime?
  mergedIntoId   String?         // surviving contact after merge

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([tenantId, contactAId, contactBId])
  @@index([tenantId, status])
  @@index([contactAId])
  @@index([contactBId])
}

// ─── CRM MODELS ─────────────────────────────────────────────────────────────────

enum DealStage {
  LEAD
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  TASK
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Company {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  domain      String?
  industry    String?
  size        String?  // e.g. "1-10", "11-50", "51-200"
  website     String?
  phone       String?
  address     String?
  city        String?
  state       String?
  postalCode  String?
  country     String?  @default("US")
  description String?  @db.Text

  deals       Deal[]
  contacts    Contact[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Contact {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Legacy link to Member during migration
  memberId    String?  @unique
  member      Member?  @relation("MemberContact", fields: [memberId], references: [id], onDelete: SetNull)

  // Identity
  externalIds Json?    // { stripeCustomerId: "...", externalSystemId: "..." }
  // Legacy scalar fields — kept for backward compat during migration to arrays
  email       String?  // @deprecated — migrate data to emails[] then remove
  phone       String?  // @deprecated — migrate data to phones[] then remove
  emails      String[] // Primary email at index 0, support multiple
  phones      String[]
  firstName   String
  lastName    String
  avatarUrl   String?
  dateOfBirth DateTime?

  // Address
  address     String?
  city        String?
  state       String?
  postalCode  String?
  country     String   @default("US")

  // Household
  householdId String?
  household   Household? @relation("ContactHousehold", fields: [householdId], references: [id], onDelete: SetNull)

  // CRM fields
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  jobTitle    String?
  linkedinUrl String?
  companyName String?  // Simple text field for company name (optional)

  source      String?  // "website", "referral", "event", "import"
  lifecycleStage LifecycleStage?
  engagementScore Int    @default(0) // computed score based on events, hours, donations, renewals
  tags        String[] @default([])
  notes       String?  @db.Text

  // Portal auth
  clerkUserId String?  @unique

  // Household relationships
  householdsAsPrimary Household[] @relation("HouseholdPrimaryContact")

  // Relationships (to be migrated from Member - added after migration)
  enrollments MembershipEnrollment[] @relation("ContactEnrollments")
  donations   Donation[] @relation("ContactDonations")
  eventRegistrations EventRegistration[] @relation("ContactEventRegistrations")
  volunteerSignups VolunteerSignup[] @relation("ContactVolunteerSignups")
  clubMemberships ClubMembership[] @relation("ContactClubMemberships")
  clubPosts    ClubPost[] @relation("ContactClubPosts")
  notifications Notification[] @relation("ContactNotifications")
  customFieldValues ContactCustomFieldValue[]
  jobPostings JobPosting[] @relation("ContactJobPostings")
  forumThreads ForumThread[] @relation("ContactForumThreads")
  forumReplies ForumReply[] @relation("ContactForumReplies")
  documents   ContactDocument[]
  chapterMemberships ChapterMember[] @relation("ContactChapterMemberships")

  // Governance
  officerTerms          OfficerTerm[]         @relation("ContactOfficerTerms")
  committeeMemberships  CommitteeMembership[] @relation("ContactCommitteeMemberships")

  // Careers
  jobApplications       JobApplication[]      @relation("ContactJobApplications")

  // Dedup
  duplicatesAsA         DuplicateSuggestion[] @relation("DuplicateA")
  duplicatesAsB         DuplicateSuggestion[] @relation("DuplicateB")

  // CRM relationships
  deals       Deal[]
  activities  Activity[]
  tasks       Task[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Soft uniqueness - allow shared emails via array
  @@index([tenantId])
  @@index([tenantId, emails])
  @@index([clerkUserId])
  @@index([householdId])
  @@index([memberId]) // Legacy during migration
  @@index([companyId])
}

model Deal {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  title       String
  description String?   @db.Text
  valueCents  Int       @default(0)
  currency    String    @default("USD")
  stage       DealStage @default(LEAD)
  probability Int       @default(0)  // 0-100
  expectedCloseDate DateTime?
  actualCloseDate   DateTime?

  source      String?  // e.g. "website", "referral", "event"
  sourceId    String?  // ID of source record (e.g. event ID)

  activities  Activity[]
  tasks       Task[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([contactId])
  @@index([companyId])
  @@index([tenantId, stage])
  @@index([expectedCloseDate])
}

model Activity {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId   String?
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  dealId      String?
  deal        Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)

  type        ActivityType
  title       String
  description String?       @db.Text
  direction   String?       // "inbound" or "outbound" for calls/emails
  duration    Int?          // in minutes
  location    String?       // for meetings

  completed   Boolean       @default(false)
  completedAt DateTime?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([tenantId])
  @@index([contactId])
  @@index([dealId])
  @@index([tenantId, type])
  @@index([completedAt])
}

model Task {
  id          String       @id @default(cuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId   String?
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  dealId      String?
  deal        Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)

  title       String
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?

  completed   Boolean      @default(false)
  completedAt DateTime?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([tenantId])
  @@index([contactId])
  @@index([dealId])
  @@index([tenantId, status])
  @@index([dueDate])
}

// ─── CHAPTERS ─────────────────────────────────────────────────────────────────

enum ChapterMemberRole {
  MEMBER
  LEADER
  ADMIN
}

model Chapter {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  slug        String
  description String?  @db.Text
  city        String?
  state       String?
  country     String?  @default("US")
  isActive    Boolean  @default(true)

  members     Member[]
  chapterMemberships ChapterMember[]
  membershipEnrollments MembershipEnrollment[] @relation("MembershipEnrollmentChapter")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model ChapterMember {
  id        String            @id @default(cuid())
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chapterId String
  chapter   Chapter           @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member            @relation(fields: [memberId], references: [id], onDelete: Cascade)
  contactId String?
  contact   Contact?          @relation("ContactChapterMemberships", fields: [contactId], references: [id], onDelete: SetNull)

  role      ChapterMemberRole @default(MEMBER)
  joinedAt  DateTime          @default(now())

  @@unique([chapterId, memberId])
  @@unique([chapterId, contactId])
  @@index([tenantId])
  @@index([chapterId])
  @@index([memberId])
  @@index([contactId])
}
